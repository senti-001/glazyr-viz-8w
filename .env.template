# Glazyr Portal — Environment Template
# Duplicate this file to .env and fill in your production credentials.

# --- Auth.js (NextAuth) ---
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret"
NEXTAUTH_URL="http://localhost:3000"

# --- GitHub OAuth ---
# Create an app at https://github.com/settings/developers
GITHUB_ID="your_github_client_id"
GITHUB_SECRET="your_github_client_secret"

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_ID="your_google_client_id"
GOOGLE_SECRET="your_google_client_secret"

# --- Managed Cloud Redis (Upstash) ---
# Get these from your Upstash Dashboard
REDIS_URL="https://your-instance.upstash.io"
REDIS_TOKEN="your_upstash_token"

# --- Local Redis (Fallback) ---
# Used only if REDIS_URL/TOKEN are missing in local dev
LOCAL_REDIS_URL="redis://localhost:6379"

# --- Base Network (RPC) ---
# Default is public mainnet.base.org if omitted
CDP_PAYMASTER_URL="https://mainnet.base.org"

# --- Google Analytics ---
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
